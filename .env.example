BRIDGE_PUBLIC_BASE_URL=http://127.0.0.1:8787
BRIDGE_RESOURCE_PATH=/mcp
BRIDGE_DB_PATH=data/bridge.sqlite3
BRIDGE_TRANSCRIPT_CHUNK_MAX_LINES=180
BRIDGE_TRANSCRIPT_CHUNK_MAX_CHARS=12000
BRIDGE_OWNER_USERNAME=owner
BRIDGE_OWNER_PASSWORD_HASH=replace-with-output-from-scripts-set-owner-password
BRIDGE_SECRET_KEY=replace-with-a-long-random-secret
BRIDGE_ACCESS_TOKEN_SECONDS=1800
BRIDGE_REFRESH_TOKEN_SECONDS=2592000
BRIDGE_AUTH_CODE_SECONDS=300
BRIDGE_AUTH_CHALLENGE_SECONDS=600
BRIDGE_SCOPE=bridge
BRIDGE_TRANSPORT_ALLOWED_HOSTS=127.0.0.1:8787,localhost:8787
BRIDGE_TRANSPORT_ALLOWED_ORIGINS=http://127.0.0.1:8787,http://localhost:8787,https://claude.ai,https://chatgpt.com,https://chat.openai.com
